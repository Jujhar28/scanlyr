# Optional: use a dedicated database for pytest so dev data is untouched.
# Export before running pytest, or copy lines into backend/.env during CI.
#
#   set TEST_DATABASE_URL=postgresql://admin:admin123@127.0.0.1:5432/shadowtest
#   cd backend
#   set DATABASE_URL=%TEST_DATABASE_URL%
#   alembic upgrade head
#   pytest tests -q
#
TEST_DATABASE_URL=postgresql://admin:admin123@127.0.0.1:5432/shadowtest
