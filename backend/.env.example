# Application
APP_NAME=Scanlyr API
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
# LOG_JSON=true
# TRUST_PROXY_HEADERS=true
# MAX_REQUEST_BODY_BYTES=1048576
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT_PER_MINUTE=120
# RATE_LIMIT_AUTH_PER_MINUTE=20
# RATE_LIMIT_SCAN_PER_MINUTE=30
# SECURITY_HSTS_MAX_AGE=31536000
# EXPOSE_ERROR_DETAILS=false
# UVICORN_WORKERS=1
# Expose Swagger (/docs) and ReDoc (/redoc). If unset: on when APP_ENV is development|dev|local or DEBUG=true.
# ENABLE_OPENAPI_DOCS=true

# Security — generate a strong secret for production
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
BCRYPT_ROUNDS=12

# PostgreSQL (psycopg v3 — URL must start with postgresql+psycopg://)
# Railway: use the DATABASE_URL provided by the Postgres plugin (often includes SSL requirements).
# Docker Compose (backend/docker-compose.yml): uses hostname `db` on the compose network.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/scanlyr

# SQLAlchemy / pooling (tune per workload; pool_recycle avoids stale connections behind proxies)
DATABASE_ECHO=false
DB_POOL_PRE_PING=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=280

# Startup behavior
# DB_SKIP_STARTUP_PING=1 — skip SELECT 1 during app startup (not recommended in prod)
# DB_REQUIRE_AT_STARTUP=1 — fail fast if DB ping fails (good for strict deployments)
# RUN_DB_MIGRATIONS_ON_STARTUP=1 — run `alembic upgrade head` inside the API process (single-worker/dev only;
#   prefer release-phase migrations on Railway or `docker/entrypoint.sh` in containers)
DB_SKIP_STARTUP_PING=false
DB_REQUIRE_AT_STARTUP=false
RUN_DB_MIGRATIONS_ON_STARTUP=false

# CORS (comma-separated origins; empty = none for credentialed requests)
CORS_ORIGINS=http://localhost:3000

# Browser URL after Microsoft OAuth (must match an allowed CORS origin for the SPA)
FRONTEND_APP_URL=http://localhost:3000

# Microsoft Graph / Entra ID (multi-tenant SaaS app registration)
# Redirect URI must point to this API, e.g. http://localhost:8000/api/v1/integrations/microsoft/callback
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/microsoft/callback
MICROSOFT_GRAPH_AUTHORITY_HOST=https://login.microsoftonline.com
MICROSOFT_GRAPH_TENANT=organizations
# Space-separated delegated scopes (admin consent). Defaults include audit + sign-in + app inventory.
# MICROSOFT_GRAPH_SCOPES=offline_access openid profile AuditLog.Read.All SignInLogs.Read.All Directory.Read.All Application.Read.All
# Optional extra entropy for encrypting stored Graph tokens (in addition to SECRET_KEY)
# MICROSOFT_GRAPH_TOKEN_PEPPER=

# Generated compliance PDFs (relative to API working directory unless absolute)
REPORT_STORAGE_DIR=var/reports

# Hybrid POST /scan: rules engine + optional AI layer (requires at least one key below)
# SCAN_AI_FUSION_ENABLED=true
# SCAN_RULES_WEIGHT=0.4
# SCAN_AI_WEIGHT=0.6
# Per-provider timeout for POST /scan AI layer (5–10 seconds)
# SCAN_AI_PROVIDER_TIMEOUT_SECONDS=10
# SCAN_AI_MAX_RETRIES=1
# Detector calibration: permissive | balanced | strict
# SCAN_STRICTNESS=balanced
# auto = Gemini primary, Groq fallback on failure
AI_PROVIDER=auto
AI_PROVIDER_TIMEOUT_SECONDS=60
# Google AI Studio: https://aistudio.google.com/apikey → Create API key → paste below
GEMINI_API_KEY=
# Free-tier Flash models: gemini-2.0-flash (default) or gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.0
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# Fast classification model (fallback path)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2
GROQ_RETRY_BACKOFF_SECONDS=0.5

# Docker entrypoint (`docker/entrypoint.sh`)
# SKIP_MIGRATIONS=1 — start uvicorn without running Alembic first
